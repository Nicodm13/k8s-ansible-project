{
  "info": {
    "name": "TaxSystem E2E Stress Test",
    "description": "Runs a full TaxSystem E2E stress scenario against previously seeded citizens and companies. Import into Postman and run with Collection Runner or Postman Performance Testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"API is healthy\", () => {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/healthz",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "healthz"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Citizen",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const citizenTarget = Number(pm.collectionVariables.get(\"citizenTarget\") || 1000);",
              "const companyTarget = Number(pm.collectionVariables.get(\"companyTarget\") || 100);",
              "const citizenIndex = Math.floor(Math.random() * citizenTarget) + 1;",
              "const companyIndex = Math.floor(Math.random() * companyTarget) + 1;",
              "",
              "const birthYear = 65 + (citizenIndex % 40);",
              "const month = ((citizenIndex * 7) % 12) + 1;",
              "const day = ((citizenIndex * 13) % 28) + 1;",
              "const serial = 1000 + citizenIndex;",
              "const cpr = `${String(day).padStart(2, \"0\")}${String(month).padStart(2, \"0\")}${String(birthYear).padStart(2, \"0\")}${String(serial).slice(-4)}`;",
              "",
              "function generateCvr(index) {",
              "  let candidate = 1000000 + index;",
              "  while (true) {",
              "    const firstSeven = String(candidate).padStart(7, \"0\").slice(-7);",
              "    const weights = [2, 7, 6, 5, 4, 3, 2];",
              "    const sum = firstSeven.split(\"\").reduce((total, digit, i) => total + Number(digit) * weights[i], 0);",
              "    const remainder = sum % 11;",
              "    const checkDigit = remainder === 0 ? 0 : 11 - remainder;",
              "    if (checkDigit !== 10) {",
              "      return `${firstSeven}${checkDigit}`;",
              "    }",
              "    candidate++;",
              "  }",
              "}",
              "const cvr = generateCvr(companyIndex);",
              "const income = 300000 + ((citizenIndex * 137) % 700000);",
              "",
              "pm.variables.set(\"citizenIndex\", String(citizenIndex));",
              "pm.variables.set(\"companyIndex\", String(companyIndex));",
              "pm.variables.set(\"cpr\", cpr);",
              "pm.variables.set(\"cvr\", cvr);",
              "pm.variables.set(\"income\", String(income));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"citizen lookup responded\", () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});",
              "",
              "pm.test(\"citizen lookup should usually exist after seeding\", () => {",
              "  if (pm.response.code === 404) {",
              "    console.warn(`Citizen ${pm.variables.get(\"cpr\")} was not found. Check that seed collection completed.`);",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/Citizen/{{cpr}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "Citizen",
            "{{cpr}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Company",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"company lookup responded\", () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});",
              "",
              "pm.test(\"company lookup should usually exist after seeding\", () => {",
              "  if (pm.response.code === 404) {",
              "    console.warn(`Company ${pm.variables.get(\"cvr\")} was not found. Check that seed collection completed.`);",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/Company/{{cvr}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "Company",
            "{{cvr}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Report Salary",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"salary report accepted\", () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 202]);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{income}}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/Company/{{cvr}}/employees/income/{{year}}/{{cpr}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "Company",
            "{{cvr}}",
            "employees",
            "income",
            "{{year}}",
            "{{cpr}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Statement",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"statement endpoint responded\", () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});",
              "",
              "pm.test(\"statement response time is acceptable\", () => {",
              "  pm.expect(pm.response.responseTime).to.be.below(Number(pm.collectionVariables.get(\"maxResponseTimeMs\") || 2000));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/StatementGenerator/{{cpr}}/Statements/{{year}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "StatementGenerator",
            "{{cpr}}",
            "Statements",
            "{{year}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Bank Transfers",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"bank transfers endpoint responded\", () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});",
              "",
              "pm.test(\"bank transfers response time is acceptable\", () => {",
              "  pm.expect(pm.response.responseTime).to.be.below(Number(pm.collectionVariables.get(\"maxResponseTimeMs\") || 2000));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/Bank/transfers/{{cpr}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "Bank",
            "transfers",
            "{{cpr}}"
          ]
        }
      },
      "response": []
    }
  ],
  "event": [],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://taxsystem.kvikit.dk",
      "type": "string"
    },
    {
      "key": "citizenTarget",
      "value": "1000",
      "type": "string"
    },
    {
      "key": "companyTarget",
      "value": "100",
      "type": "string"
    },
    {
      "key": "year",
      "value": "2026",
      "type": "string"
    },
    {
      "key": "maxResponseTimeMs",
      "value": "2000",
      "type": "string"
    }
  ]
}
