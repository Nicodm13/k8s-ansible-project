{
  "info": {
    "name": "TaxSystem CSV Seed Test Data",
    "description": "Seeds companies and citizens from taxsystem-test-data.csv. Run the collection with the CSV as iteration data. A company is created only when seedCompany=true; one citizen is created per row.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check (first CSV row only)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Avoid making the same health request for every CSV row.",
              "if (pm.info.iteration > 0) {",
              "  pm.execution.skipRequest();",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"API is healthy\", () => {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/healthz",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "healthz"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Seed Company when seedCompany=true",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const shouldSeed = String(pm.iterationData.get(\"seedCompany\") || \"\")",
              "  .trim()",
              "  .toLowerCase() === \"true\";",
              "",
              "if (!shouldSeed) {",
              "  pm.execution.skipRequest();",
              "} else {",
              "  const required = [\"cvr\", \"companyName\"];",
              "  const missing = required.filter((key) => {",
              "    const value = pm.iterationData.get(key);",
              "    return value === undefined || value === null || String(value).trim() === \"\";",
              "  });",
              "",
              "  if (missing.length > 0) {",
              "    throw new Error(`CSV row ${pm.info.iteration + 1} is missing: ${missing.join(\", \")}`);",
              "  }",
              "",
              "  pm.variables.set(\"cvr\", String(pm.iterationData.get(\"cvr\")));",
              "  pm.variables.set(\"companyName\", String(pm.iterationData.get(\"companyName\")));",
              "  console.log(`Seeding company row ${pm.info.iteration + 1}: ${pm.variables.get(\"cvr\")} ${pm.variables.get(\"companyName\")}`);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"company seed response is acceptable\", () => {",
              "  if (![200, 201, 202, 409].includes(pm.response.code)) {",
              "    console.error(`Company seed failed with ${pm.response.code}: ${pm.response.text()}`);",
              "  }",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 409]);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/Company",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "Company"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"CVR\": \"{{cvr}}\",\n  \"Name\": \"{{companyName}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": []
    },
    {
      "name": "Seed Citizen",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const required = [",
              "  \"firstName\", \"lastName\", \"cpr\", \"streetAddress\",",
              "  \"city\", \"zipCode\", \"bankAccountNumber\"",
              "];",
              "",
              "const missing = required.filter((key) => {",
              "  const value = pm.iterationData.get(key);",
              "  return value === undefined || value === null || String(value).trim() === \"\";",
              "});",
              "",
              "if (missing.length > 0) {",
              "  throw new Error(`CSV row ${pm.info.iteration + 1} is missing: ${missing.join(\", \")}`);",
              "}",
              "",
              "for (const key of required) {",
              "  pm.variables.set(key, String(pm.iterationData.get(key)));",
              "}",
              "console.log(`Seeding citizen row ${pm.info.iteration + 1}: ${pm.variables.get(\"cpr\")} ${pm.variables.get(\"firstName\")} ${pm.variables.get(\"lastName\")}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"citizen seed response is acceptable\", () => {",
              "  if (![200, 201, 202, 409].includes(pm.response.code)) {",
              "    console.error(`Citizen seed failed with ${pm.response.code}: ${pm.response.text()}`);",
              "  }",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 409]);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/Citizen",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "Citizen"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"{{firstName}}\",\n  \"lastName\": \"{{lastName}}\",\n  \"cpr\": \"{{cpr}}\",\n  \"streetAddress\": \"{{streetAddress}}\",\n  \"city\": \"{{city}}\",\n  \"zipCode\": \"{{zipCode}}\",\n  \"bankAccountNumber\": \"{{bankAccountNumber}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": []
    }
  ],
  "event": [],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://taxsystem.kvikit.dk",
      "type": "string"
    }
  ]
}
