{
  "info": {
    "_postman_id": "bc8bf6c5-e76e-4aa1-a827-60e844130b19",
    "name": "TaxSystem CSV E2E Stress Test",
    "description": "Runs the complete TaxSystem scenario once per row in taxsystem-test-data.csv. The CSV supplies cpr, cvr, income, and year.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Avoid making the same health request for every CSV row.",
              "if (pm.info.iteration > 0) {",
              "  pm.execution.skipRequest();",
              "}"
            ],
            "id": "0eb54816-c701-4519-b6cc-9e451ab5e61b"
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"API is healthy\", () => {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "id": "629c8ea8-3b92-49bb-bc3a-1e06fcfa1266"
          }
        }
      ],
      "id": "bedcee18-500d-4061-a1da-849c42d91ae8",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/healthz",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "healthz"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Citizen",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const required = [\"cpr\", \"cvr\", \"income\"];",
              "const missing = required.filter((key) => {",
              "  const value = pm.iterationData.get(key);",
              "  return value === undefined || value === null || String(value).trim() === \"\";",
              "});",
              "",
              "const csvYear = pm.iterationData.get(\"year\");",
              "const fallbackYear = pm.collectionVariables.get(\"year\");",
              "const resolvedYear = csvYear === undefined || csvYear === null || String(csvYear).trim() === \"\"",
              "  ? fallbackYear",
              "  : csvYear;",
              "",
              "if (missing.length > 0) {",
              "  throw new Error(`CSV row ${pm.info.iteration + 1} is missing: ${missing.join(\", \")}`);",
              "}",
              "",
              "pm.variables.set(\"year\", String(resolvedYear));"
            ],
            "id": "49ad33ee-3b44-4439-92f7-284f3dff000c"
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"citizen lookup responded\", () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});",
              "",
              "pm.test(\"citizen should exist after seeding\", () => {",
              "  if (pm.response.code === 404) {",
              "    console.warn(`Citizen ${pm.iterationData.get(\"cpr\")} was not found.`);",
              "  }",
              "});",
              "pm.test(\"response time is acceptable\", () => {",
              "  const maximum = Number(pm.collectionVariables.get(\"maxResponseTimeMs\") || 2000);",
              "  pm.expect(pm.response.responseTime).to.be.below(maximum);",
              "});"
            ],
            "id": "8d7bf0ed-f782-4d2e-8c0a-6ed336f61724"
          }
        }
      ],
      "id": "1e8bec06-509d-472a-94b7-6416571f9f5a",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/Citizen/{{cpr}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "Citizen",
            "{{cpr}}"
          ]
        }
      },
      "response": []
    },
